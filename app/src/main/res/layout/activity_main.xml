<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tela">

    <!-- CONTEÚDO PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="38dp"
        android:paddingBottom="28dp">

        <!-- Ícone superior -->
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_play"
            android:scaleType="fitCenter"
            android:contentDescription="Ícone de corrida" />

        <!-- Texto TEMPO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="TEMPO"
            android:textColor="#9BA6AA"
            android:textSize="8sp"
            android:letterSpacing="0.08" />

        <!-- Timer principal -->
        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="#FFFFFF"
            android:textSize="23sp"
            android:textStyle="bold"
            android:layout_marginTop="0dp" />

        <!-- Área de informações -->
        <LinearLayout
            android:layout_width="165dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="5dp">

            <!-- Linha 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal">

                <!-- Distância -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="match_parent"
                        android:text="⌖"
                        android:textColor="#00E060"
                        android:textSize="11sp"
                        android:gravity="top|center_horizontal" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DISTÂNCIA"
                            android:textColor="#8D999E"
                            android:textSize="5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="km"
                            android:textColor="#8D999E"
                            android:textSize="6sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#13262E" />

                <!-- Ritmo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="match_parent"
                        android:text="↻"
                        android:textColor="#00E060"
                        android:textSize="11sp"
                        android:gravity="top|center_horizontal" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RITMO"
                            android:textColor="#8D999E"
                            android:textSize="5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="min/km"
                            android:textColor="#8D999E"
                            android:textSize="6sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#13262E" />

            <!-- Linha 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal">

                <!-- Calorias -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="match_parent"
                        android:text="♨"
                        android:textColor="#00E060"
                        android:textSize="11sp"
                        android:gravity="top|center_horizontal" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CALORIAS"
                            android:textColor="#8D999E"
                            android:textSize="5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="kcal"
                            android:textColor="#8D999E"
                            android:textSize="6sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#13262E" />

                <!-- Frequência Cardíaca -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:padding="2dp">

                    <TextView
                        android:layout_width="12dp"
                        android:layout_height="match_parent"
                        android:text="♡"
                        android:textColor="#00E060"
                        android:textSize="11sp"
                        android:gravity="top|center_horizontal" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FREQ."
                            android:textColor="#8D999E"
                            android:textSize="5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="bpm"
                            android:textColor="#8D999E"
                            android:textSize="6sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Botão Play -->
        <ImageButton
            android:id="@+id/btnPlay"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/bg_botao_play"
            android:src="@drawable/ic_play"
            android:scaleType="center"
            android:padding="11dp"
            android:contentDescription="Play" />

        <!-- Botão Stop escondido -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="Stop" />

    </LinearLayout>

    <!-- BOTÃO PERFIL FIXO POR CIMA -->
    <TextView
        android:id="@+id/btnIrPerfil"
        android:layout_width="68dp"
        android:layout_height="24dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_botao_perfil"
        android:gravity="center"
        android:text="PERFIL"
        android:textColor="#00E060"
        android:textSize="8sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>