<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000B10">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="8dp">

            <!-- Cabeçalho pequeno -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFIL"
                android:textColor="#9BA6AA"
                android:textSize="6sp"
                android:letterSpacing="0.08" />

            <!-- Avatar menor -->
            <TextView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="JM"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <!-- Nome -->
            <TextView
                android:id="@+id/txtNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Joice Martins"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <!-- Descrição -->
            <TextView
                android:id="@+id/txtDescricao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Corredora iniciante"
                android:textColor="#8D999E"
                android:textSize="6sp" />

            <!-- Card de informações -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_card_perfil"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFO"
                    android:textColor="#00E060"
                    android:textSize="5sp"
                    android:textStyle="bold" />

                <!-- Idade -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="11dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Idade"
                        android:textColor="#8D999E"
                        android:textSize="6sp" />

                    <TextView
                        android:id="@+id/txtIdade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16 anos"
                        android:textColor="#FFFFFF"
                        android:textSize="6sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#13262E" />

                <!-- Nível -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="11dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nível"
                        android:textColor="#8D999E"
                        android:textSize="6sp" />

                    <TextView
                        android:id="@+id/txtNivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Iniciante"
                        android:textColor="#FFFFFF"
                        android:textSize="6sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#13262E" />

                <!-- Objetivo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="11dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Meta"
                        android:textColor="#8D999E"
                        android:textSize="6sp" />

                    <TextView
                        android:id="@+id/txtObjetivo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 km"
                        android:textColor="#FFFFFF"
                        android:textSize="6sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Estatísticas mini -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_perfil"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Treinos"
                        android:textColor="#8D999E"
                        android:textSize="4sp" />
                </LinearLayout>

                <Space
                    android:layout_width="3dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_perfil"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.4"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Km"
                        android:textColor="#8D999E"
                        android:textSize="4sp" />
                </LinearLayout>

                <Space
                    android:layout_width="3dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_perfil"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="320"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kcal"
                        android:textColor="#8D999E"
                        android:textSize="4sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Meta mini -->
            <LinearLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_card_perfil"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="META"
                    android:textColor="#00E060"
                    android:textSize="5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Correr 5 km por semana."
                    android:textColor="#FFFFFF"
                    android:textSize="6sp"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>